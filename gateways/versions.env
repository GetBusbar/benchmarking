# SPDX-License-Identifier: Apache-2.0
# ─────────────────────────────────────────────────────────────────────────────────────────────────
# EXACTLY what each gateway is built from. This is the ONLY place source refs live — nothing is
# hidden in a script. Override any line (env or edit) to build a different ref; the runner records
# the version/commit ACTUALLY built into every results/memory/<gw>.json (`build` field), so the
# output always discloses what was measured. "You chose an old branch" is answerable by pointing here
# and at the recorded commit.
#
# Sourced by the runner before each gateway manifest; manifests read these with `${VAR:-default}`.
# ─────────────────────────────────────────────────────────────────────────────────────────────────

# Busbar — built from the working tree in this repo (the version + git SHA are recorded).
: "${BUSBAR_REF:=working-tree}"

# LiteLLM-Rust — BerriAI's compiled AI-gateway beta.
#   The only PUBLIC branch whose /v1/messages route exists is litellm_rust_gateway_v1_messages_route.
#   (The gateway README references litellm_rust_messages_route, which does not exist.) Set
#   LITELLM_RUST_COMMIT to pin an exact commit; empty = branch HEAD (recorded either way).
: "${LITELLM_RUST_REPO:=https://github.com/BerriAI/litellm}"
: "${LITELLM_RUST_BRANCH:=litellm_rust_gateway_v1_messages_route}"
: "${LITELLM_RUST_COMMIT:=}"

# Bifrost — pinned container image (its own published tag).
: "${BIFROST_IMAGE:=maximhq/bifrost:v1.6.4}"

# LiteLLM-Python — pip package. Empty = latest on PyPI at run time; pin e.g. LITELLM_PY_SPEC='litellm[proxy]==1.60.0'.
: "${LITELLM_PY_SPEC:=litellm[proxy]}"

# Portkey — OSS gateway via npx. Pin e.g. PORTKEY_SPEC='@portkey-ai/gateway@1.11.0'; the resolved
# version is recorded in the result.
: "${PORTKEY_SPEC:=@portkey-ai/gateway}"
