# SPDX-License-Identifier: Apache-2.0
# ─────────────────────────────────────────────────────────────────────────────────────────────────
# EXACTLY what each gateway is built from. This is the ONLY place source refs live — nothing is
# hidden in a script. Override any line (env or edit) to build a different ref; the runner records
# the version/commit ACTUALLY built into every results/memory/<gw>.json (`build` field), so the
# output always discloses what was measured. "You chose an old branch" is answerable by pointing here
# and at the recorded commit.
#
# Sourced by the runner before each gateway manifest; manifests read these with `${VAR:-default}`.
# ─────────────────────────────────────────────────────────────────────────────────────────────────

# Busbar — the RELEASED image users download; the static binary is extracted from it and run
# natively (multi-arch musl). Override BUSBAR_BIN to benchmark a local working-tree build instead.
: "${BUSBAR_IMAGE:=getbusbar/busbar:1.4.1}"

# LiteLLM-Rust — BerriAI's compiled AI-gateway beta.
#   The only PUBLIC branch whose /v1/messages route exists is litellm_rust_gateway_v1_messages_route.
#   (The gateway README references litellm_rust_messages_route, which does not exist.)
#   PINNED like every other gateway: an empty commit floated to branch HEAD, which let their
#   numbers move between field runs while everyone else was frozen. Bump this sha DELIBERATELY
#   (with a commit message) when adopting a newer beta build.
: "${LITELLM_RUST_REPO:=https://github.com/BerriAI/litellm}"
: "${LITELLM_RUST_BRANCH:=litellm_rust_gateway_v1_messages_route}"
: "${LITELLM_RUST_COMMIT:=698072308b}"

# Bifrost — pinned container image (its own published tag).
: "${BIFROST_IMAGE:=maximhq/bifrost:v1.6.4}"

# LiteLLM-Python — pip package. Empty = latest on PyPI at run time; pin e.g. LITELLM_PY_SPEC='litellm[proxy]==1.60.0'.
: "${LITELLM_PY_SPEC:=litellm[proxy]}"

# Portkey — OSS gateway via npx. Pin e.g. PORTKEY_SPEC='@portkey-ai/gateway@1.11.0'; the resolved
# version is recorded in the result.
: "${PORTKEY_SPEC:=@portkey-ai/gateway}"

# Kong Gateway — OSS image; the ai-proxy plugin fronts /v1/chat/completions and its upstream_url is
# overridden to the mock (DB-less declarative config). Pin a tag; recorded in the result.
: "${KONG_IMAGE:=kong:3.8}"

# Helicone AI Gateway — Rust OSS router. BUILT FROM SOURCE (no arm64 image is published), run native;
# the openai provider's base-url is overridden to the mock. Pin an exact commit; empty = branch HEAD.
: "${HELICONE_REPO:=https://github.com/Helicone/ai-gateway}"
: "${HELICONE_COMMIT:=9649b27bdc9fb0907d359e899894102a15f3a085}"

# GoModel (ENTERPILOT/GOModel) — Go OpenAI+Anthropic gateway; OPENAI_BASE_URL is overridden to the
# mock. Pin a tag; the resolved image is recorded in the result.
: "${GOMODEL_IMAGE:=enterpilot/gomodel:0.1.55}"

# ── Documented-but-not-yet-drop-in (kept OUT of run-all's default list; see each gateway.sh header) ──
# One-API — single container; channels + tokens are runtime admin-API state (the manifest scripts it).
# Pinned to v0.6.10 because that tag ships a real linux/arm64 manifest (`:latest` is amd64-only), so it
# runs natively on Graviton like everything else.
: "${ONE_API_IMAGE:=justsong/one-api:v0.6.10}"
# agentgateway — Rust agent/LLM data plane; the ghcr multiarch image ships linux/arm64. Bare proxy
# (no backendAuth/backendTLS), observability off. Note the leading "v" in the tag.
: "${AGENTGATEWAY_IMAGE:=ghcr.io/agentgateway/agentgateway:v1.3.1}"
# TensorZero — Rust gateway; the multiarch image ships linux/arm64. Pure-proxy (observability off).
: "${TENSORZERO_IMAGE:=tensorzero/gateway:2026.6.0}"
# Apache APISIX + ai-proxy plugin — DB-less/standalone (no etcd); arm64 debian image.
: "${APISIX_IMAGE:=apache/apisix:3.17.0-debian}"
# Arch (Katanemo) — Envoy data plane + Arch services in one arm64 container, via the archgw CLI.
: "${ARCH_VERSION:=0.3.22}"
# NOTE: Envoy AI Gateway is intentionally NOT in this benchmark — it is Kubernetes-native (Envoy
# Gateway + CRDs, a full cluster), not a single-box drop-in, which is out of scope for this harness.
